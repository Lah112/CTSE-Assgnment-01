# DriveCore — Inventory Service
# Copy this file to .env and fill in the values for your environment.
# Never commit the real .env file to source control.

# ---- Application ----
PORT=3003
NODE_ENV=development

# ---- Database (PostgreSQL) ----
# Full connection string consumed by the pg Pool in src/config/db.js
# Format: postgresql://<user>:<password>@<host>:<port>/<database>
DATABASE_URL=postgresql://postgres:password@localhost:5432/inventory_db

# Uncomment and set to "true" if your Postgres instance requires SSL
# (e.g., cloud-managed databases such as AWS RDS, Supabase, Render).
# DB_SSL=false

# ---- Inter-Service Communication ----
# Base URL of the Auth (User) Service.
# Used by POST /api/inventory to verify userId before inserting a record.
#
# Local development:  http://localhost:3001
# Docker Compose:     http://drivecore-user-service:3001
AUTH_SERVICE_URL=http://localhost:3001

# ---- CORS ----
# Origin(s) allowed to call this service.
# In production, set this to your API Gateway or frontend domain.
CORS_ORIGIN=http://localhost:3000
