// ── Prisma Client Generator ───────────────────────────────────────────────────
generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl", "linux-musl-openssl-3.0.x"]
}

// ── Data Source (PostgreSQL via Neon) ─────────────────────────────────────────
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Enums ─────────────────────────────────────────────────────────────────────

enum ServiceType {
  OIL_CHANGE
  TIRE_ROTATION
  BRAKE_SERVICE
  GENERAL_INSPECTION
  ENGINE_REPAIR
  TRANSMISSION_SERVICE
  AC_SERVICE
  WHEEL_ALIGNMENT
}

enum BookingStatus {
  PENDING      // Default on creation — awaiting confirmation
  CONFIRMED    // Service centre has accepted the booking
  IN_PROGRESS  // Vehicle is currently being serviced
  COMPLETED    // Service finished
  CANCELLED    // Cancelled by user or service centre
}

// ── Booking Model ─────────────────────────────────────────────────────────────

model Booking {
  // Primary key — UUID generated by Prisma
  id            String        @id @default(uuid())

  // Foreign key to the User service (UUID held as plain String — no DB-level FK
  // because the users table lives in a separate service/database)
  userId        String

  vehicleNumber String        // e.g. "WP CAB-1234"
  date          DateTime      // Desired appointment date-time (UTC)
  serviceType   ServiceType
  status        BookingStatus @default(PENDING)
  notes         String?       // Optional additional instructions from the user

  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  // Index on userId for fast lookup by GET /api/bookings/:userId
  @@index([userId])
  @@map("bookings")
}
