# ── Application ───────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3002

# ── PostgreSQL via Neon (Prisma reads DATABASE_URL directly) ───────────────
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=verify-full&channel_binding=require

# ── Inter-Service Communication ────────────────────────────────────────────
# URL of the User & Auth Service.
# Local dev:   http://localhost:3001
# Docker:      http://auth-service:3001
# Production:  http://<auth-service-ip>:3001
AUTH_SERVICE_URL=http://localhost:3001

# ── CORS ───────────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:3000
